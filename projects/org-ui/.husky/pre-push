#!/usr/bin/env sh
# Keep main in sync with origin before push (auto-release adds version bumps on remote).
branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
if [ "$branch" != "main" ]; then
  exit 0
fi

git fetch origin main 2>/dev/null || exit 0

behind="$(git rev-list --count HEAD..origin/main 2>/dev/null || echo 0)"
if [ "$behind" = "0" ]; then
  exit 0
fi

echo "origin/main is ${behind} commit(s) ahead (often auto-release version bumps). Rebasing..."
git pull --rebase origin main
