FROM node:22-alpine3.19 AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install --ignore-scripts

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_WS_URL
ARG NEXT_PUBLIC_VENDOR_API_URL
ARG NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
ARG NEXT_PUBLIC_AUTH0_DOMAIN
ARG NEXT_PUBLIC_AUTH0_CLIENT_ID
ARG NEXT_PUBLIC_AUTH0_SCOPE
ARG NEXT_PUBLIC_AUTH0_AUDIENCE
ARG NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
ARG NEXT_PUBLIC_POSTHOG_KEY
ARG NEXT_PUBLIC_POSTHOG_HOST
ARG CSP_API_DOMAIN
ARG CSP_SCRIPT_SOURCES
ARG CSP_ANALYTICS_DOMAINS
ARG CSP_IMG_SOURCES
ARG CSP_CONNECT_SOURCES
ARG CSP_FRAME_SOURCES
ARG CSP_FONT_SOURCES
ARG CSP_STYLE_SOURCES
ARG CSP_MANIFEST_DOMAIN
ARG CSP_ENABLED

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_VENDOR_API_URL=$NEXT_PUBLIC_VENDOR_API_URL
ENV NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=$NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
ENV NEXT_PUBLIC_AUTH0_DOMAIN=$NEXT_PUBLIC_AUTH0_DOMAIN
ENV NEXT_PUBLIC_AUTH0_CLIENT_ID=$NEXT_PUBLIC_AUTH0_CLIENT_ID
ENV NEXT_PUBLIC_AUTH0_SCOPE=$NEXT_PUBLIC_AUTH0_SCOPE
ENV NEXT_PUBLIC_AUTH0_AUDIENCE=$NEXT_PUBLIC_AUTH0_AUDIENCE
ENV NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=$NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_POSTHOG_KEY=$NEXT_PUBLIC_POSTHOG_KEY
ENV NEXT_PUBLIC_POSTHOG_HOST=$NEXT_PUBLIC_POSTHOG_HOST
ENV CSP_API_DOMAIN=$CSP_API_DOMAIN
ENV CSP_SCRIPT_SOURCES=$CSP_SCRIPT_SOURCES
ENV CSP_ANALYTICS_DOMAINS=$CSP_ANALYTICS_DOMAINS
ENV CSP_IMG_SOURCES=$CSP_IMG_SOURCES
ENV CSP_CONNECT_SOURCES=$CSP_CONNECT_SOURCES
ENV CSP_FRAME_SOURCES=$CSP_FRAME_SOURCES
ENV CSP_FONT_SOURCES=$CSP_FONT_SOURCES
ENV CSP_STYLE_SOURCES=$CSP_STYLE_SOURCES
ENV CSP_MANIFEST_DOMAIN=$CSP_MANIFEST_DOMAIN
ENV CSP_ENABLED=$CSP_ENABLED

COPY . .

RUN npm run security:tanstack

RUN --mount=type=secret,id=stripe_secret_key \
    STRIPE_SECRET_KEY=$(cat /run/secrets/stripe_secret_key) npm run build

FROM node:22-alpine3.19

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=80
ENV HOSTNAME=0.0.0.0

# Copy the Next.js build output
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/package-lock.json ./package-lock.json

# Install production dependencies, skip prepare script (husky not needed in production)
RUN npm install --production --ignore-scripts

EXPOSE 80

CMD ["npm", "start"]
