# API URLs
NEXT_PUBLIC_API_URL="frontend api url here"
NEXT_PUBLIC_VENDOR_API_URL="vendor api url here"
NEXT_PUBLIC_WS_URL="ws://frontend ws url here"

# Auth0 Configuration
NEXT_PUBLIC_AUTH0_DOMAIN="your-auth0-domain.com"
NEXT_PUBLIC_AUTH0_CLIENT_ID="your-auth0-client-id"
NEXT_PUBLIC_AUTH0_SCOPE="openid profile email offline_access"
NEXT_PUBLIC_AUTH0_AUDIENCE="https://your-api-url.com/"

# PostHog Analytics (optional - leave empty to disable)
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Stripe Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"

# Content Security Policy (CSP) Configuration
# Comma-separated list of allowed domains for each directive

# Backend API domain (supports http, https, ws, wss)
CSP_API_DOMAIN="your-api-domain.com"

# External script sources (CDNs, third-party scripts, analytics)
# Example: cdn.jsdelivr.net,maps.googleapis.com,js.stripe.com,static.cloudflareinsights.com,us-assets.i.posthog.com
CSP_SCRIPT_SOURCES="your-cdn-domain.com,your-analytics-domain.com"

# Analytics and tracking domains (for API calls)
# Example: api.posthog.com,us.i.posthog.com
CSP_ANALYTICS_DOMAINS="your-analytics-api.com"

# Image sources (CDNs, external image hosts)
# Example: images.unsplash.com,cdn.example.com
# Leave empty to allow all https images
CSP_IMG_SOURCES=""

# Style sources (external stylesheets, Google Fonts CSS)
# Example: fonts.googleapis.com
CSP_STYLE_SOURCES="your-font-provider.com"

# Font sources (font files, Google Fonts assets, font CDNs)
# Example: fonts.gstatic.com
CSP_FONT_SOURCES="your-font-cdn.com"

# Additional connect-src domains (APIs, WebSockets, payment processors, analytics assets)
# Example: maps.googleapis.com,api.stripe.com,auth0-domain.com,us-assets.i.posthog.com,your-app-domain.com
CSP_CONNECT_SOURCES="your-external-api.com,your-auth-provider.com"

# Frame sources (iframes for payments, authentication)
# Example: js.stripe.com,hooks.stripe.com,auth0-domain.com,your-auth0-tenant.auth0.com
CSP_FRAME_SOURCES="your-payment-provider.com,your-auth-provider.com"

# Manifest domain (PWA manifest.json host, Cloudflare Access)
# Example: app.fieldflow360.com,fieldflow360.cloudflareaccess.com
CSP_MANIFEST_DOMAIN="your-app-domain.com"

# Enable/disable CSP (true/false) - useful for debugging
CSP_ENABLED="true"
