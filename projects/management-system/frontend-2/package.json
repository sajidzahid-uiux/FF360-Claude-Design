{
  "name": "cms-frontend",
  "version": "0.1.86",
  "private": true,
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:clean": "rm -rf .next && next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "prepare": "husky",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "changelog:generate": "conventional-changelog -p angular -i CHANGELOG.md -s -o CHANGELOG.md --tag-prefix frontend-v",
    "changelog:generate:first": "conventional-changelog -p angular -i CHANGELOG.md -s -r 1 -o CHANGELOG.md",
    "changelog:version": "node scripts/changelog-and-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "types:docs": "typedoc",
    "types:docs:watch": "typedoc --watch",
    "typecheck:tests": "tsc -p tsconfig.vitest.json --noEmit",
    "org-ui:local": "npm install file:../../FF-org-UI && npm run build --prefix ../../FF-org-UI",
    "org-ui:registry": "npm install @fieldflow360/org-ui@0.1.51"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.3.0",
    "@deck.gl/core": "9.3.3",
    "@deck.gl/google-maps": "9.3.3",
    "@deck.gl/layers": "9.3.3",
    "@fieldflow360/org-ui": "file:vendor/fieldflow360-org-ui-0.1.58.tgz",
    "@hookform/resolvers": "^5.2.2",
    "@react-google-maps/api": "^2.20.6",
    "@react-pdf/renderer": "^4.3.0",
    "@stripe/stripe-js": "^7.9.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query": "5.76.1",
    "@tanstack/react-table": "8.21.3",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.485.0",
    "next": "^16.2.7",
    "posthog-js": "^1.252.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.68.0",
    "react-icons": "^5.5.0",
    "sonner": "^2.0.7",
    "stripe": "^20.0.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "^1.2.5",
    "zod": "^4.1.13",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@faker-js/faker": "^9.9.0",
    "@mantine/hooks": "^8.0.1",
    "@next/eslint-plugin-next": "^16.2.7",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.19.26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^4.7.0",
    "conventional-changelog-angular": "^7.0.0",
    "conventional-changelog-cli": "^4.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-win32-x64-msvc": "4.1.7",
    "lightningcss-win32-x64-msvc": "1.30.1"
  },
  "overrides": {
    "react-is": "^19.0.0-rc-69d4b800-20241021",
    "@tanstack/query-core": "5.76.0",
    "@tanstack/table-core": "8.21.3",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1",
    "deck.gl": "9.3.3",
    "@deck.gl/core": "9.3.3",
    "@deck.gl/layers": "9.3.3",
    "@deck.gl/google-maps": "9.3.3",
    "@deck.gl/aggregation-layers": "9.3.3",
    "@deck.gl/geo-layers": "9.3.3",
    "@deck.gl/mesh-layers": "9.3.3",
    "@deck.gl/extensions": "9.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": "prettier --write"
  }
}
