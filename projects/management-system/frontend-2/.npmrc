# Supply-chain hardening (TanStack incident 2026-05-11, GHSA-g7cv-rxg3-hmpx).
# Keep a lockfile and avoid silent lockfile drift in CI/local installs.
package-lock=true

# LOCAL PROTOTYPE OVERRIDE (FF360 Claude Design workspace):
# org-ui is consumed from the sibling local build via a file: dependency in
# package.json ("@fieldflow360/org-ui": "file:../../org-ui"), so the GitHub
# Packages registry + auth token are no longer required to install. The
# original lines are kept here, commented, for reference / restoring CI:
#   @fieldflow360:registry=https://npm.pkg.github.com
#   //npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
#   always-auth=true

# Always use the official npm registry — overrides any runner-level mirror config.
registry=https://registry.npmjs.org

# Deck.gl family is pinned to a single version via package.json "overrides"; peer
# ranges don't all agree, so installs need legacy peer resolution (matches the
# Netlify NPM_FLAGS=--legacy-peer-deps and the Vercel installCommand).
legacy-peer-deps=true
