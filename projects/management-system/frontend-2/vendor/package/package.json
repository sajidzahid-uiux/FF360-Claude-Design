{
  "name": "@fieldflow360/org-ui",
  "version": "0.1.58",
  "description": "Shared UI component library for FieldFlow360 Organization",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": {
      "style": "./dist/styles.css",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "dist/styles.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fieldflow360/org-ui"
  },
  "bugs": {
    "url": "https://github.com/fieldflow360/org-ui/issues"
  },
  "homepage": "https://github.com/fieldflow360/org-ui#readme",
  "scripts": {
    "build": "npm run build:release",
    "build:release": "npm run clean && npm run build:js && npm run build:css",
    "build:verify-apps": "cd dev-app && npm run build && cd ../consumer-app && npm run build",
    "build:js": "tsup --config tsup.config.ts",
    "build:css": "npx @tailwindcss/cli --input src/styles.css --output dist/styles.css --minify",
    "dev:package": "tsup --config tsup.config.ts --watch",
    "dev:css": "npx @tailwindcss/cli --input src/styles.css --output dist/styles.css --watch",
    "clean": "rm -rf dist",
    "dev": "cd dev-app && npm run dev",
    "lint": "eslint src --ext .ts,.tsx",
    "preview": "cd consumer-app && npm run dev",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "fieldflow360"
  ],
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": ">=7.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": false
    },
    "react-hook-form": {
      "optional": false
    },
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "autoprefixer": "^10.4.16",
    "cpy-cli": "^6.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lucide-react": "^0.562.0",
    "postcss": "^8.4.32",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.0",
    "tailwindcss": "^4.0.0-beta.10",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.2",
    "@deck.gl/layers": "^9.3.2",
    "@hookform/resolvers": "^5.2.2",
    "clsx": "^2.0.0",
    "deck.gl": "^9.3.2",
    "maplibre-gl": "^5.24.0",
    "react-map-gl": "^8.1.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.2.0"
  }
}
